  <!-- ═══════════════════════════════════════════════
       FAQ
  ════════════════════════════════════════════════ -->
  <section class="py-20 bg-stone-50" aria-labelledby="faq-heading">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12 animate-on-scroll">
          <p class="section-label mb-3">FAQ</p>
          <h2 id="faq-heading" class="section-heading">
            Questions About Pool Construction
          </h2>
        </div>

        <div class="space-y-2">
          {faqs.map((faq) => (
            <div class="faq-item bg-white rounded-2xl border border-stone-200 overflow-hidden animate-on-scroll">
              <button class="faq-trigger w-full flex items-center justify-between gap-4 px-6 py-5 text-left hover:bg-stone-50 transition-colors" aria-expanded="false">
                <span class="font-sans font-semibold text-navy-900 text-sm sm:text-base leading-snug">{faq.q}</span>
                <span class="faq-icon w-7 h-7 rounded-full bg-aqua-50 text-aqua-600 text-xl flex items-center justify-center flex-shrink-0 leading-none font-light" aria-hidden="true">+</span>
              </button>
              <div class="faq-answer">
                <p class="font-sans text-stone-500 text-sm leading-relaxed px-6 pb-5">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FINAL CTA — one intentional dark section
  ════════════════════════════════════════════════ -->
  <section class="relative py-24 overflow-hidden bg-navy-900" aria-labelledby="cta-heading">
    <!-- BG image -->
    <div class="absolute inset-0">
      <img src={`${b}/images/pool-2.jpg`} alt="" class="w-full h-full object-cover opacity-20" loading="lazy" aria-hidden="true" width="1920" height="600" />
      <div class="absolute inset-0 bg-gradient-to-r from-navy-900/95 via-navy-900/80 to-navy-900/60"></div>
    </div>

    <div class="relative z-10 container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
        <div class="animate-on-scroll">
          <p class="section-label text-aqua-400 mb-3">Ready to Start?</p>
          <h2 id="cta-heading" class="section-heading-white mb-5">
            Let's Build Your<br />Dream Pool
          </h2>
          <p class="font-sans text-stone-300 text-lg leading-relaxed mb-8">
            Free, no-obligation consultation. We'll assess your site, listen to your vision, and provide a detailed custom quote — all within 24 hours.
          </p>
          <div class="flex flex-wrap gap-4 items-center">
            <a href="tel:0403866061" class="btn-primary">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
              </svg>
              Call Brad: 0403 866 061
            </a>
            <a href={`${b}/contact`} class="btn-white">Get a Quote Online</a>
          </div>
        </div>

        <!-- Inline form on white card -->
        <div class="animate-on-scroll">
          <div class="bg-white rounded-2xl p-7 shadow-hero">
            <h3 class="font-serif text-navy-900 text-xl mb-1">Request a Free Quote</h3>
            <p class="font-sans text-stone-500 text-sm mb-5">We'll respond within 24 hours.</p>

            <form action="https://formspree.io/f/xdavjokn" method="POST" class="space-y-4" novalidate>
              <input type="hidden" name="_subject" value="New Pool Quote — Mediterranean Pools" />
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label for="c-name" class="form-label">Name *</label>
                  <input type="text" id="c-name" name="name" required autocomplete="name" placeholder="Your name" class="form-input" />
                </div>
                <div>
                  <label for="c-phone" class="form-label">Phone *</label>
                  <input type="tel" id="c-phone" name="phone" required autocomplete="tel" placeholder="04xx xxx xxx" class="form-input" />
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div>
                  <label for="c-email" class="form-label">Email *</label>
                  <input type="email" id="c-email" name="email" required placeholder="your@email.com" class="form-input" />
                </div>
                <div>
                  <label for="c-suburb" class="form-label">Suburb *</label>
                  <input type="text" id="c-suburb" name="suburb" required placeholder="e.g. Paddington" class="form-input" />
                </div>
              </div>
              <div>
                <label for="c-budget" class="form-label">Budget</label>
                <select id="c-budget" name="budget" class="form-input text-stone-500">
                  <option value="" disabled selected>Select budget...</option>
                  {['Under $40k','$40k–$60k','$60k–$80k','$80k–$100k','$100k+','Not sure'].map((b) => (
                    <option value={b}>{b}</option>
                  ))}
                </select>
              </div>
              <button type="submit" class="btn-primary w-full py-3.5 justify-center">Send My Free Quote</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button id="lightbox-close" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 text-white text-2xl flex items-center justify-center transition-colors z-10" aria-label="Close">×</button>
    <img id="lightbox-img" src="" alt="" class="relative z-10" />
    <p id="lightbox-caption" class="absolute bottom-5 left-1/2 -translate-x-1/2 text-white/60 text-xs font-sans text-center max-w-md z-10 px-4"></p>
  </div>

</BaseLayout>
