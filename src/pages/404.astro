---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { b } from '../utils/base';
---

<BaseLayout
  title="Page Not Found | Mediterranean Pools Qld"
  description="The page you're looking for doesn't exist. Return to Mediterranean Pools Qld homepage."
>
  <Header />
  <main class="min-h-screen flex items-center bg-white pt-20">
    <div class="container-custom py-20 text-center">
      <p class="font-serif text-aqua-400 text-8xl mb-6">404</p>
      <h1 class="font-serif text-navy-900 text-3xl mb-4">Page Not Found</h1>
      <p class="font-sans text-navy-500 text-base max-w-md mx-auto mb-8">
        Sorry, we couldn't find the page you were looking for. Let's get you back on track.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`${b}/`} class="btn-primary">Back to Homepage</a>
        <a href={`${b}/contact`} class="btn-outline">Get a Quote</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
